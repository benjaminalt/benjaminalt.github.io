	keywords = {my, Optimization, Program Synthesis, Industrial Robotics, Neurosymbolic Artificial Intelligence},
	pages = {532--537},
	file = {ScienceDirect Snapshot:/home/ben/Zotero/storage/9EJ58Y6K/S2212827124012824.html:text/html},
}

