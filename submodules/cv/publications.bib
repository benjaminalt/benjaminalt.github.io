	file = {Full Text PDF:/home/ben/Zotero/storage/FGUCJREM/Schultheis et al. - 2024 - EASY Energy-Efficient Analysis and Control Processes in the Dynamic Edge-Cloud Continuum for Indust.pdf:application/pdf},
